// ignore_for_file: type=lint
mixin _$GraphDaoMixin on DatabaseAccessor<AppDatabase> {
  $RelationshipEdgesTableTable get relationshipEdgesTable =>
      attachedDatabase.relationshipEdgesTable;
  $GroupMemoriesTableTable get groupMemoriesTable =>
      attachedDatabase.groupMemoriesTable;
  $GroupMembersTableTable get groupMembersTable =>
      attachedDatabase.groupMembersTable;
}
